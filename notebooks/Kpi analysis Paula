   "source": [
    "KPI- Sessions per client\n",
    "This KPI measures user frequency and persistence. It calculates how many distinct visits a single user makes to the funnel."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 29,
   "id": "77eda02d-0f40-4ba1-8f5b-d2a866bf7695",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Web Part 1: 1.30 sesions per client\n",
      "Web Part 2: 1.24 sesions per client\n",
      "Diference: -0.06 sesions per client\n"
     ]
    }
   ],
   "source": [
    "def calculate_sessions_per_client(df):\n",
    "    sessions_by_client = df.groupby('client_id')['visit_id'].nunique() #count the visits per client\n",
    "    return sessions_by_client.mean() #average per session\n",
    "\n",
    "# Calculate the KPI\n",
    "avg_sessions1 = calculate_sessions_per_client(web_pt1)\n",
    "avg_sessions2 = calculate_sessions_per_client(web_pt2)\n",
    "\n",
    "\n",
    "print(f\"Web Part 1: {avg_sessions1:.2f} sesions per client\")\n",
    "print(f\"Web Part 2: {avg_sessions2:.2f} sesions per client\")\n",
    "print(f\"Diference: {avg_sessions2 - avg_sessions1:.2f} sesions per client\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ad769193-8f11-4b33-bd84-87b237edfbe5",
   "metadata": {},
   "outputs": [],
   "source": [
    "completion = df_web[df_web['process_step'] == 'confirm'].groupby('client_id')['visit_id'].nunique().gt(0).astype(int)\n",
    "\n",
    "# B. Time: Tiempo promedio que pasa el cliente en el funnel (sumando todas sus sesiones)\n",
    "session_duration = df_web.groupby(['client_id', 'visit_id'])['date_time'].agg(lambda x: (x.max() - x.min()).total_seconds())\n",
    "avg_time_client = session_duration.groupby('client_id').mean()\n",
    "\n",
    "# C. Errors: ¿El cliente tuvo algún retroceso (backward step) en alguna de sus visitas?\n",
    "df_web['is_backward'] = df_web.groupby(['client_id', 'visit_id'])['step_value'].diff() < 0\n",
    "has_errors = df_web.groupby('client_id')['is_backward'].any().astype(int)\n",
    "\n",
    "# 2. Crear el DataFrame Final por Cliente\n",
    "client_summary = pd.DataFrame({\n",
    "    'completed_process': completion,\n",
    "    'avg_time_funnel': avg_time_client,\n",
    "    'total_steps_avg': df_web.groupby('client_id')['visit_id'].count() / df_web.groupby('client_id')['visit_id'].nunique(),\n",
    "    'has_navigation_errors': has_errors\n",
    "}).fillna(0).reset_index()\n",
    "\n",
    "print(client_summary.head())"
   ]
